# Copy to .env and fill in. Never commit .env.
# All features gracefully degrade to mock mode when keys are missing.

# ── Claude API (brief generation, comment drafting) ──────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Slack (the spine — everything flows through Slack) ──────
# See docs/SLACK_SETUP.md for the 5-minute setup.
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123456789
SLACK_WORKSPACE_URL=https://your-workspace.slack.com

# ── Optional: real posting credentials (Tier 2, not day one) ──
BUFFER_ACCESS_TOKEN=
METRICOOL_API_KEY=

# ── Optional: OpenAI (Whisper API fallback; local whisper works without) ──
OPENAI_API_KEY=

# ── Runtime flags ────────────────────────────────────────────
# "mock" = prints to terminal instead of posting to Slack
# "real" = posts for real (requires SLACK_BOT_TOKEN)
RUNTIME_MODE=mock

# Timezone for daily brief scheduling (IANA)
TIMEZONE=Australia/Sydney
